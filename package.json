{
  "name": "tailwind-nextjs-starter-blog",
  "version": "2.0.2",
  "private": true,
  "scripts": {
    "start": "next dev",
    "dev": "concurrently \"cross-env INIT_CWD=$PWD next dev\" \"velite dev\"",
    "build": "cross-env next build",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "eslint --fix app components lib layouts",
    "prepare": "husky"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "esbuild": "0.18.11",
    "github-slugger": "^1.4.0",
    "gray-matter": "^4.0.3",
    "image-size": "1.0.0",
    "js-yaml": "^4.1.1",
    "kbar": "^0.1.0-beta.48",
    "mdast-util-to-string": "^3.2.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.8",
    "probe-image-size": "^7.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-preset-minify": "^7.0.1",
    "rehype-prism-plus": "^2.0.2",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^3.4.17",
    "unist-util-visit": "^4.1.0",
    "velite": "^0.3.1"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mdx": "^2.0.13",
    "@types/probe-image-size": "^7.2.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.28.0",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@3.6.1"
}
